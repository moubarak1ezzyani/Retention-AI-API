# ------------------------------------------------
# 1. PYTHON & SYSTEM (Standard)
# ------------------------------------------------
# Byte-compiled / Optimized files (Python temporary files)
__pycache__/
*.py[cod]
*$py.class

# Unnecessary Mac/Windows system files
.DS_Store
Thumbs.db

# ------------------------------------------------
# 2. SECURITY & ENVIRONMENT (CRITICAL)
# ------------------------------------------------
# Environment variables (Passwords, API Keys)
# NEVER COMMIT THIS FILE
.env
.env.local

# Virtual Environments
venv/
env/
.venv/
RHvenv/

# ------------------------------------------------
# 3. MACHINE LEARNING & DATA (Large files)
# ------------------------------------------------
# Datasets and raw data (Avoid bloating Git)
*.csv
*.xlsx
*.xls
*.json
# If you have a dedicated folder for data:
data/
datasets/

# Trained models (Often > 100MB)
*.pkl
*.joblib
*.h5
*.pt
*.onnx
# If you store models in a dedicated folder:
models/

# Jupyter Notebook checkpoints (Clutter folders created by Jupyter)
.ipynb_checkpoints/

# ------------------------------------------------
# 4. BACKEND & IDE
# ------------------------------------------------
# Local database (SQLite) for FastAPI
*.db
*.sqlite3

# IDE configuration files (VS Code, PyCharm)
.vscode/
.idea/